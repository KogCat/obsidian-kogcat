{
  "name": "obsidian-kog-cat",
  "version": "0.13.6",
  "description": "KogCat — a review pass that calibrates your own thinking against a knowledge base of cognitive biases, anti-patterns, and your past notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs",
    "lint:check": "(prettier --check --cache --cache-strategy content --cache-location node_modules/.cache/.prettiercache .) && (eslint .)",
    "lint:fix": "(prettier --write --cache --cache-strategy content --cache-location node_modules/.cache/.prettiercache .) && (eslint --fix .)",
    "type:check": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "jest src/test/e2e",
    "i18n:check": "node scripts/i18n-check.mjs",
    "mock:om-core": "node scripts/mock-om-core.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@types/jest": "^29.5.13",
    "@types/node": "^16.11.6",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jest": "^29.7.0",
    "obsidian": "latest",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "tslib": "2.4.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.35.0",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "fflate": "^0.8.3",
    "i18next": "^26.1.0",
    "js-tiktoken": "^1.0.15",
    "lucide-react": "^0.447.0",
    "minimatch": "^10.0.1",
    "openai": "^6.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.7",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
